{
  "wave": "W000",
  "runtime_governance": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "version": "1.0.0",
    "wave": "W000",
    "runtime_state_machine": {
      "states": [
        {
          "id": "planned",
          "description": "Work is defined but not yet in execution."
        },
        {
          "id": "active",
          "description": "Work is in execution and producing telemetry."
        },
        {
          "id": "sweep",
          "description": "MCP sweep analyzes near-miss and obsolete artifacts."
        },
        {
          "id": "closed",
          "description": "Work is either merged, archived, or pruned."
        }
      ],
      "transitions": [
        {
          "from": "planned",
          "to": "active",
          "trigger": "approved"
        },
        {
          "from": "active",
          "to": "sweep",
          "trigger": "completed_or_aborted"
        },
        {
          "from": "sweep",
          "to": "closed",
          "trigger": "classified"
        }
      ]
    }
  },
  "agent_registry": {
    "version": "1.0.0",
    "agents": [
      {
        "id": "abacus-governor",
        "role": "governance-orchestrator",
        "owner": "ABACUS",
        "capabilities": [
          "state-machine-control",
          "telemetry-aggregation",
          "policy-enforcement"
        ]
      },
      {
        "id": "codex-worker",
        "role": "execution-worker",
        "owner": "CODEX",
        "capabilities": [
          "patch-generation",
          "test-execution",
          "pr-preparation"
        ]
      },
      {
        "id": "mcp-sweep-mop",
        "role": "post-session-curator",
        "owner": "ABACUS",
        "capabilities": [
          "near-miss-detection",
          "obsolete-pruning",
          "remediation-ticketing"
        ]
      }
    ]
  },
  "federation_registry": {
    "version": "1.0.0",
    "federation_links": [
      {
        "id": "office-link",
        "kind": "exploit",
        "provider": "FEDERATION",
        "interface": "api",
        "purpose": "document-processing"
      },
      {
        "id": "diagram-link",
        "kind": "exploit",
        "provider": "FEDERATION",
        "interface": "api",
        "purpose": "diagram-rendering"
      },
      {
        "id": "binary-link",
        "kind": "exploit",
        "provider": "FEDERATION",
        "interface": "api",
        "purpose": "external-binary-execution"
      }
    ],
    "policies": {
      "prefer_exploit_over_integrate": true,
      "max_parallel_feature_branches": 3
    }
  }
}