{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GBOGEB/ABACUS/schemas/telemetry.schema.json",
  "title": "ABACUS Telemetry Dispatch Payload",
  "description": "Structured telemetry emitted by ABACUS for CODEX technical artifact rendering.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "payload_version",
    "source",
    "generated_at",
    "status",
    "summary",
    "metrics",
    "artifacts"
  ],
  "properties": {
    "payload_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "ref", "sha", "run_id"],
      "properties": {
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha": {
          "type": "string",
          "minLength": 7
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["success", "warning", "failure"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": ["number", "integer", "string", "boolean"]
          },
          "unit": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["success", "warning", "failure", "unknown"]
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "mime_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "links": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  }
}
